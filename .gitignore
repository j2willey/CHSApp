# =============================================================================
# CHS app .gitignore
# Goal: source code (index.html, admin.html, *.py, *.js, *.gs, *.md) is tracked.
# Data files, images, secrets, and backups must NEVER be committed.
# App assets (PDFs/PNGs) live in camphisierraapp/public/assets, NOT here.
# =============================================================================

# ---- Firebase / service-account credentials — NEVER commit ----
serviceAccountKey.json
*-adminsdk-*.json
*serviceAccount*.json
*service-account*.json
*.key.json
*-deploy-key.json
secrets/
.secrets/
.env
.env.*
!.env.example

# ---- Data files (PII: camp registration, scout names, rosters, attendance) ----
*.csv
*.tsv
*.xlsx
*.xls
*.xlsm
*.xltx
*.xlsx#

# ---- Documents / rosters (belong in Firebase, not the repo) ----
*.pdf
*.doc
*.docx

# ---- Images / headshots (binary, large - go to Firebase Storage) ----
headshots_resized/
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.tif
*.webp
*.heic
*.ico

# ---- Backups / corrupted / temp copies ----
*.bak
*.backup
*.corrupted*
*.orig
*.tmp
*~

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# ---- Editor / OS clutter ----
.~lock.*
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo

# ---- Accidental empty files ----
/python
/cd
